<configs>
	<!--add a weight to the helmet mods to allow them to be scrrapped. Scrap will be 75% of the weight value in iron-->
	<append xpath="/item_modifiers/item_modifier[@name='modArmorPerception']"><property name="Weight" value="334"/></append>
	<append xpath="/item_modifiers/item_modifier[@name='modArmorStrength']"><property name="Weight" value="334"/></append>
	<append xpath="/item_modifiers/item_modifier[@name='modArmorFortitude']"><property name="Weight" value="334"/></append>
	<append xpath="/item_modifiers/item_modifier[@name='modArmorAgility']"><property name="Weight" value="334"/></append>
	<append xpath="/item_modifiers/item_modifier[@name='modArmorIntellect']"><property name="Weight" value="334"/></append>
	<append xpath="/item_modifiers/item_modifier[@name='modArmorTreasureHunter']"><property name="Weight" value="334"/></append>
	<append xpath="/item_modifiers/item_modifier[@name='modArmorNightVision']"><property name="Weight" value="334"/></append>
	
	<!--cant scrap modArmorInsulatedLinerT1/T2/T3 for some reason in 2.5 even though they are cloth so add weight to force scrap option-->
	<append xpath="/item_modifiers/item_modifier[@name='modArmorInsulatedLinerT1']"><property name="Weight" value="20"/></append>
	<append xpath="/item_modifiers/item_modifier[@name='modArmorInsulatedLinerT2']"><property name="Weight" value="20"/></append>
	<append xpath="/item_modifiers/item_modifier[@name='modArmorInsulatedLinerT3']"><property name="Weight" value="20"/></append>
</configs>